{
  "name": "opencode-mcp-vscode",
  "displayName": "OpenCode Chat Panel",
  "description": "%extension.description%",
  "version": "1.0.10",
  "publisher": "Pacoaldev",
  "repository": {
    "type": "git",
    "url": "https://github.com/fralopala2/opencode-mcp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "AI",
    "Chat"
  ],
  "icon": "resources/logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencode.ask",
        "title": "%command.ask%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "opencode.reconnect",
        "title": "%command.reconnect%"
      },
      {
        "command": "opencode.newSession",
        "title": "%command.newSession%"
      },
      {
        "command": "opencode.addFileToContext",
        "title": "%command.addFileToContext%"
      },
      {
        "command": "opencode.addSelectionToContext",
        "title": "%command.addSelectionToContext%"
      },
      {
        "command": "opencode.addOpenFilesToContext",
        "title": "%command.addOpenFilesToContext%"
      },
      {
        "command": "opencode.setApiKeys",
        "title": "%command.setApiKeys%"
      },
      {
        "command": "opencode.clearApiKeys",
        "title": "%command.clearApiKeys%"
      }
    ],
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:4096",
          "description": "%config.serverUrl.desc%"
        },
        "opencode.serverPort": {
          "type": "number",
          "default": 4096,
          "description": "%config.serverPort.desc%"
        },
        "opencode.serverUsername": {
          "type": "string",
          "default": "opencode",
          "description": "%config.serverUsername.desc%"
        },
        "opencode.serverPassword": {
          "type": "string",
          "default": "",
          "description": "%config.serverPassword.desc%"
        },
        "opencode.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoStartServer.desc%"
        },
        "opencode.defaultAgent": {
          "type": "string",
          "default": "",
          "description": "%config.defaultAgent.desc%"
        },
        "opencode.autoApprovePermissions": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoApprovePermissions.desc%"
        },
        "opencode.bin": {
          "type": "string",
          "default": "",
          "description": "%config.bin.desc%"
        },
        "opencode.quickActions": {
          "type": "array",
          "default": [
            {
              "label": "Explicar archivo actual",
              "text": "Explica el archivo seleccionado",
              "icon": "info"
            },
            {
              "label": "Buscar bugs",
              "text": "Encuentra posibles bugs en el código actual",
              "icon": "bug"
            },
            {
              "label": "Generar tests",
              "text": "Genera tests unitarios para las funciones del archivo",
              "icon": "test"
            },
            {
              "label": "Refactorizar",
              "text": "Refactoriza el código para mejorar la legibilidad",
              "icon": "refactor"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "text"
            ]
          },
          "description": "%config.quickActions.desc%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode",
          "title": "%view.container.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "opencode": [
        {
          "type": "webview",
          "id": "opencode.mcp",
          "name": "%view.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "opencode.addSelectionToContext",
          "group": "navigation@99",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode.addFileToContext",
          "group": "navigation@99"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode.addFileToContext",
          "group": "navigation@99",
          "when": "resourceLangId != ''"
        }
      ],
      "commandPalette": [
        {
          "command": "opencode.ask"
        },
        {
          "command": "opencode.reconnect"
        },
        {
          "command": "opencode.newSession"
        },
        {
          "command": "opencode.addFileToContext"
        },
        {
          "command": "opencode.addSelectionToContext"
        },
        {
          "command": "opencode.addOpenFilesToContext"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencode.ask",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o"
      },
      {
        "command": "opencode.addFileToContext",
        "key": "ctrl+alt+shift+f",
        "mac": "cmd+alt+shift+f"
      },
      {
        "command": "opencode.addSelectionToContext",
        "key": "ctrl+alt+shift+s",
        "mac": "cmd+alt+shift+s",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npx esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-rewrite-relative-links"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.17.0"
  }
}